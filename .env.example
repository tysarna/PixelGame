# AWS Profile (set up via `aws configure --profile pixel-social`)
AWS_PROFILE=pixel-social

# Image Generation API (set on Lambda directly, not here — contains secrets)
# IMAGE_GEN_API_KEY=sk-...
# IMAGE_GEN_PROVIDER=openai

# Override ALB DNS for local client testing (copy from CDK output)
# ALB_DNS_NAME=your-alb-dns.cloudfront.net

# Override CloudFront domain for local client testing
# CLOUDFRONT_DOMAIN=d1234.cloudfront.net
